        </div>
        <div style="width:40px;height:2px;background:#e0e0e0;margin:0 4px 16px;"></div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
          <div style="width:28px;height:28px;border-radius:50%;background:#e0e0e0;color:#999;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;">3</div>
          <span style="font-size:9px;color:#999;white-space:nowrap;">完了</span>
        </div>
      </div>
      <!-- Role selection -->
      <div style="display:flex;gap:10px;margin-bottom:24px;">
        <div class="m-card" style="flex:1;padding:18px 12px;text-align:center;border:2px solid #000;position:relative;">
          <span class="m-badge" style="position:absolute;top:8px;right:8px;background:#000;color:#fff;font-size:9px;">おすすめ</span>
          <span class="material-icons-outlined" style="font-size:32px;color:#000;margin:0 0 8px;">shopping_bag</span>
          <p style="font-size:14px;font-weight:700;color:#000;">カスタマー</p>
          <p style="font-size:11px;color:#999;margin-top:4px;line-height:1.4;">AIが提案する香りを注文</p>
        </div>
        <div class="m-card" style="flex:1;padding:18px 12px;text-align:center;position:relative;">
          <span class="material-icons-outlined" style="font-size:32px;color:#999;margin:0 0 8px;">palette</span>
          <p style="font-size:14px;font-weight:700;color:#555;">クリエーター</p>
          <p style="font-size:11px;color:#999;margin-top:4px;line-height:1.4;">レシピを提供して収益を得る</p>
          <p style="font-size:10px;color:#d97706;font-weight:600;margin-top:6px;">審査あり</p>
        </div>
      </div>
      <!-- Form fields -->
      <div style="display:flex;flex-direction:column;gap:16px;">
