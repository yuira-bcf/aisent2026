<!-- ===== JS ===== -->
<script>
function go(name) {
  document.querySelectorAll('.screen-wrap').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.drawer .nav-btn').forEach(b => b.classList.remove('active'));
  const screen = document.getElementById('screen-' + name);
  if (screen) screen.classList.add('active');
  // Highlight drawer nav
  document.querySelectorAll('.drawer .nav-btn').forEach(b => {
    if (b.getAttribute('onclick') === "go('" + name + "')") b.classList.add('active');
  });
  // Close drawer
  document.getElementById('drawer-overlay').classList.remove('open');
}
function toggleDrawer() {
  document.getElementById('drawer-overlay').classList.toggle('open');
}
function switchVersion(v) {
  var v1 = document.getElementById('result-v1');
  var v2 = document.getElementById('result-v2');
  var b1 = document.getElementById('btn-v1');
  var b2 = document.getElementById('btn-v2');
  if (v === 1) {
    v1.style.display = 'block';
    v2.style.display = 'none';
    b1.style.background = '#000'; b1.style.color = '#fff'; b1.style.border = 'none';
    b2.style.background = '#fff'; b2.style.color = '#999'; b2.style.border = '1px solid #e0e0e0';
  } else {
    v1.style.display = 'none';
    v2.style.display = 'block';
    b2.style.background = '#000'; b2.style.color = '#fff'; b2.style.border = 'none';
    b1.style.background = '#fff'; b1.style.color = '#999'; b1.style.border = '1px solid #e0e0e0';
  }
}
/* ── Award switcher ── */
var awardData = [
  { icon:'🏆', title:'フレッシュフローラル賞', desc:'フレッシュ×フローラル象限で最も優れた調香を行ったクリエーターに贈られる賞。シトラスや軽やかな花の香料を巧みに使い、爽やかさと華やかさを両立した調香が対象。', badge:'x < 0, y > 0', meta:'2025 春期 ・ 対象者 18名' },
  { icon:'🏆', title:'ウォームフローラル賞', desc:'ウォーム×フローラル象限で最高の調香を達成したクリエーターに贈られる賞。バニラやアンバーの温かみとローズやジャスミンの華やかさを融合させた、深みのあるフローラルが対象。', badge:'x > 0, y > 0', meta:'2025 春期 ・ 対象者 14名' },
  { icon:'🏆', title:'フレッシュウッディ賞', desc:'フレッシュ×ウッディ象限で卓越した調香を行ったクリエーターに贈られる賞。シトラスやマリンの爽快感とシダーウッドやベチバーの落ち着きを組み合わせた、清涼感ある調香が対象。', badge:'x < 0, y < 0', meta:'2025 春期 ・ 対象者 12名' },
  { icon:'🏆', title:'ウォームウッディ賞', desc:'ウォーム×ウッディ象限で最も優れた調香を行ったクリエーターに贈られる賞。サンダルウッドやウードの重厚なベースにスパイスやアンバーを重ねた、深みのあるオリエンタル調が対象。', badge:'x > 0, y < 0', meta:'2025 春期 ・ 対象者 16名' },
  { icon:'🏆', title:'ゴールデンブレンド賞', desc:'全象限を通じて最高の総合スコアを記録したクリエーターに贈られる最高賞。評価・調香数・リピート率・お気に入り数の全指標で突出した実績が求められる。', badge:'全象限対象', meta:'2025 春期 ・ 対象者 52名' },
  { icon:'💖', title:'最多お気に入り賞', desc:'シーズン中に最も多くのユーザーからお気に入り登録されたクリエーターに贈られる賞。幅広いユーザー層から支持される親しみやすい調香力が評価される。', badge:'お気に入り数', meta:'2025 春期 ・ 対象者 52名' },
  { icon:'🔄', title:'シグネチャーセント賞', desc:'最も高いリピート率を記録したクリエーターに贈られる賞。一度依頼したユーザーが繰り返し指名する「あの人にまた頼みたい」と思わせる信頼と品質の証。', badge:'リピート率', meta:'2025 春期 ・ 対象者 38名' },
  { icon:'💡', title:'イノベーション賞', desc:'従来にない斬新な香料の組み合わせや、ユニークなコンセプトで新しい香りの可能性を切り拓いたクリエーターに贈られる賞。審査員特別選考。', badge:'審査員選考', meta:'2025 春期 ・ 候補者 10名' },
  { icon:'🌐', title:'万能クリエーター賞', desc:'全4象限にわたってバランスよく高品質な調香を行ったクリエーターに贈られる賞。特定の領域に偏らず、幅広いジャンルで安定した実力を発揮する万能性が評価される。', badge:'全象限カバー率', meta:'2025 春期 ・ 対象者 22名' },
  { icon:'⭐', title:'新人賞', desc:'登録から6ヶ月以内のクリエーターの中で最も優れた成績を収めた新人に贈られる賞。将来が期待される才能の発掘と奨励を目的とする。', badge:'登録6ヶ月以内', meta:'2025 春期 ・ 対象者 8名' },
  { icon:'📖', title:'ベストストーリー賞', desc:'AI生成ストーリーの元となるコンセプトが最も魅力的で、ユーザーの共感を集めたクリエーターに贈られる賞。香りの背景にある物語性と世界観の構築力が評価される。', badge:'ストーリー評価', meta:'2025 春期 ・ 対象者 52名' },
  null, /* 11: シーズンマスター — 動的に生成 */
  { icon:'🗳️', title:'コミュニティ投票賞', desc:'ユーザー投票によって選ばれるクリエーター人気賞。毎シーズン末にノミネートされた上位5名の中からユーザーの直接投票で受賞者を決定する、最も民主的な賞。', badge:'ユーザー投票', meta:'2025 春期 ・ 投票数 1,247票' },
  { icon:'👑', title:'殿堂入り', desc:'年間マスターを通算3度受賞したクリエーターに贈られる最高栄誉。長年にわたりプラットフォームのトップに君臨し続けた功績を称え、プロフィールに永久バッジが付与される。', badge:'年間マスター3度受賞', meta:'累計 ・ 殿堂入り 1名' },
];

var seasonMasterData = {
  '年間': { icon:'📊', emoji:'📊', title:'年間マスター', desc:'年間を通じて最も優れた活躍を見せたクリエーターに贈られる年間総合賞。全4シーズンの成績を統合し、通年で安定した品質と人気を維持した総合力が評価される。', badge:'年間総合', baseCount:'52名' },
  '春': { icon:'🌸', emoji:'🌸', title:'シーズンマスター 春', desc:'春シーズン（4〜6月）に最も活躍したクリエーターに贈られる季節限定賞。桜・フリージア・ミモザなど春の素材を活かし、季節感あふれる調香で多くのユーザーを魅了した実績が対象。', badge:'春シーズン（4-6月）', baseCount:'30名' },
  '夏': { icon:'☀️', emoji:'☀️', title:'シーズンマスター 夏', desc:'夏シーズン（7〜9月）に最も活躍したクリエーターに贈られる季節限定賞。シトラス・マリン・ミントなど夏の清涼素材を駆使し、暑さの中でも心地よい香りを提供した実績が対象。', badge:'夏シーズン（7-9月）', baseCount:'28名' },
  '秋': { icon:'🍂', emoji:'🍂', title:'シーズンマスター 秋', desc:'秋シーズン（10〜12月）に最も活躍したクリエーターに贈られる季節限定賞。金木犀・シナモン・ウッディノートなど秋の深みある素材で、季節の移ろいを香りに表現した実績が対象。', badge:'秋シーズン（10-12月）', baseCount:'25名' },
  '冬': { icon:'❄️', emoji:'❄️', title:'シーズンマスター 冬', desc:'冬シーズン（1〜3月）に最も活躍したクリエーターに贈られる季節限定賞。バニラ・アンバー・スパイスなど温もりのある素材で、寒い季節に寄り添う香りを創出した実績が対象。', badge:'冬シーズン（1-3月）', baseCount:'22名' },
};

var currentSeason = '年間';

function getSeasonMaster() {
  var sm = seasonMasterData[currentSeason];
  var year = document.getElementById('award-year').value.replace('年','');
  var period = currentSeason === '年間' ? year + ' 年間総合' : year + ' ' + currentSeason + '期';
  return { icon:sm.icon, title:sm.title, desc:sm.desc, badge:sm.badge, meta:period + ' ・ 対象者 ' + sm.baseCount };
}

function switchSeason(el) {
  document.querySelectorAll('.season-btn').forEach(function(b) { b.classList.remove('season-btn-active'); });
  el.classList.add('season-btn-active');
  var text = el.textContent.trim();
  if (text.indexOf('年間') !== -1) currentSeason = '年間';
  else if (text.indexOf('春') !== -1) currentSeason = '春';
  else if (text.indexOf('夏') !== -1) currentSeason = '夏';
  else if (text.indexOf('秋') !== -1) currentSeason = '秋';
  else if (text.indexOf('冬') !== -1) currentSeason = '冬';
  var isAnnual = (currentSeason === '年間');
  // 品質・人気賞: 年間のみ
  document.getElementById('award-group-quality').style.display = isAnnual ? '' : 'none';
  // 年間マスター: 年間のみ（シーズン時はシーズンマスター）
  var chip = document.getElementById('season-master-chip');
  var sm = seasonMasterData[currentSeason];
  chip.querySelector('.award-row-icon').textContent = sm.emoji;
  document.getElementById('season-master-name').textContent = sm.title;
  document.getElementById('season-master-sub').textContent = sm.badge + 'の最優秀';
  // コミュニティ投票賞: 年間のみ
  document.getElementById('award-community-chip').style.display = isAnnual ? '' : 'none';
  // 殿堂入り: 年間のみ
  document.getElementById('award-hof-chip').style.display = isAnnual ? '' : 'none';
  // If an annual-only award was selected and we switched to seasonal, reset to first award
  if (!isAnnual) {
    var activeRow = document.querySelector('.award-row-active');
    if (activeRow && (activeRow.style.display === 'none' || activeRow.closest('#award-group-quality'))) {
      var first = document.querySelector('.award-row[onclick*="switchAward(this,0)"]');
      if (first) switchAward(first, 0);
    }
  }
  // If season master is currently selected, update header too
  if (chip.classList.contains('award-row-active')) {
    switchAward(chip, 11);
  }
}

function switchAward(el, idx) {
  document.querySelectorAll('.award-row').forEach(function(c) { c.classList.remove('award-row-active'); });
  el.classList.add('award-row-active');
  var d = (idx === 11) ? getSeasonMaster() : awardData[idx];
  document.getElementById('award-icon').textContent = d.icon;
  document.getElementById('award-title').textContent = d.title;
  document.getElementById('award-desc').textContent = d.desc;
  document.getElementById('award-badge').innerHTML = '<span class="material-icons-outlined" style="font-size:11px;margin:0;">map</span> ' + d.badge;
  document.getElementById('award-meta').textContent = d.meta;
}

function saveBlend(ver) {
  var btn = document.getElementById('order-btn-' + ver);
  btn.style.opacity = '1';
  btn.style.pointerEvents = 'auto';
  var saveBtn = event.currentTarget;
  saveBtn.innerHTML = '<span class="material-icons-outlined" style="font-size:18px;margin-right:6px;">bookmark</span>保存済み';
  saveBtn.style.opacity = '0.6';
  saveBtn.style.pointerEvents = 'none';
}

/* ── Swipe-to-delete ── */
var swipeStartX = 0;
var swipeDx = 0;
var activeSwipeRow = null;

function swipeStart(e, row) {
  // close any other open rows
  document.querySelectorAll('.swipe-row.open').forEach(function(r) {
    if (r !== row) r.classList.remove('open');
  });
  swipeStartX = e.touches[0].clientX;
  swipeDx = 0;
  activeSwipeRow = row;
  var card = row.querySelector('.swipe-card');
  card.style.transition = 'none';
}

function swipeMove(e, row) {
  var dx = e.touches[0].clientX - swipeStartX;
  if (row.classList.contains('open')) dx -= 72;
  dx = Math.min(0, Math.max(-72, dx));
  swipeDx = dx;
  var card = row.querySelector('.swipe-card');
  card.style.transform = 'translateX(' + dx + 'px)';
}

function swipeEnd(row) {
  var card = row.querySelector('.swipe-card');
  card.style.transition = 'transform 0.25s ease';
  if (swipeDx < -36) {
    row.classList.add('open');
    card.style.transform = 'translateX(-72px)';
  } else {
    row.classList.remove('open');
    card.style.transform = 'translateX(0)';
  }
  activeSwipeRow = null;
}

function deleteHistory(row) {
  row.style.maxHeight = row.offsetHeight + 'px';
  row.offsetHeight; // force reflow
  row.classList.add('removing');
  setTimeout(function() { row.remove(); }, 300);
}

// close swipe on tap outside
document.addEventListener('touchstart', function(e) {
  document.querySelectorAll('.swipe-row.open').forEach(function(row) {
    if (!row.contains(e.target)) {
      row.classList.remove('open');
      var card = row.querySelector('.swipe-card');
      card.style.transform = 'translateX(0)';
    }
  });
});
</script>
</body>
</html>
