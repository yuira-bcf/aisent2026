              </div>
              <div style="flex:1;display:flex;flex-direction:column;gap:3px;">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span><span style="flex:1;color:#333;">レモン</span><input type="text" value="20" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#EC4899;flex-shrink:0;"></span><span style="flex:1;color:#333;">ベルガモット</span><input type="text" value="15" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#8B5CF6;flex-shrink:0;"></span><span style="flex:1;color:#333;">ラベンダー</span><input type="text" value="15" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#3B82F6;flex-shrink:0;"></span><span style="flex:1;color:#333;">シダーウッド</span><input type="text" value="15" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#10B981;flex-shrink:0;"></span><span style="flex:1;color:#333;">ムスク</span><input type="text" value="15" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;"><span style="width:8px;height:8px;border-radius:50%;background:#F97316;flex-shrink:0;"></span><span style="flex:1;color:#333;">シーブルー</span><input type="text" value="20" style="width:32px;text-align:right;font-weight:600;color:#000;font-size:12px;border:1px solid #e0e0e0;border-radius:4px;padding:1px 4px;background:#fff;"><span style="font-size:12px;color:#000;margin-left:1px;">%</span></div>
                <button style="display:flex;align-items:center;justify-content:center;gap:4px;width:100%;padding:6px 0;margin-top:4px;border:1px dashed #ccc;border-radius:6px;background:transparent;color:#999;font-size:11px;cursor:pointer;"><span class="material-icons-outlined" style="font-size:14px;">add</span>フレグランスを追加</button>
              </div>
            </div>
          </div>

          <!-- Note Structure v1 -->
