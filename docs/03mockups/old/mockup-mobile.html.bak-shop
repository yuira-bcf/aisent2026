        </div>
      </div>

      <div style="padding:12px 16px;display:flex;flex-direction:column;gap:10px;">
        <!-- History Card 1 -->
        <div class="swipe-row" ontouchstart="swipeStart(event,this)" ontouchmove="swipeMove(event,this)" ontouchend="swipeEnd(this)">
          <div class="swipe-action" onclick="deleteHistory(this.parentElement)">
            <span class="material-icons-outlined" style="font-size:20px;">delete</span>削除
          </div>
          <div class="swipe-card m-card" style="padding:14px;cursor:pointer;" onclick="go('history-detail')">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="donut-sm" style="background:conic-gradient(#F59E0B 0% 15%,#EC4899 15% 25%,#8B5CF6 25% 45%,#3B82F6 45% 60%,#10B981 60% 75%,#F97316 75% 85%,#EF4444 85% 100%);">
                <div class="donut-sm-hole"></div>
              </div>
              <div style="flex:1;">
                <div style="display:flex;align-items:center;gap:6px;">
                  <p style="font-size:14px;font-weight:600;color:#000;">夏の風 — Sweet</p>
                  <span class="m-badge" style="background:#000;color:#fff;">v2</span>
                </div>
                <p style="font-size:11px;color:#999;margin-top:2px;">2026/02/14 — 7種配合</p>
              </div>
              <span class="material-icons-outlined" style="font-size:18px;color:#ccc;margin:0;">chevron_right</span>
            </div>
            <div style="display:flex;gap:4px;margin-top:8px;flex-wrap:wrap;">
              <span style="font-size:9px;background:#f0f0f0;padding:2px 6px;border-radius:4px;color:#666;">夏</span>
              <span style="font-size:9px;background:#f0f0f0;padding:2px 6px;border-radius:4px;color:#666;">デート</span>
