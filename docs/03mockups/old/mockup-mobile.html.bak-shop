          <label class="m-input-label">ニックネーム</label>
          <input class="m-input" type="text" placeholder="はなこ">
          <p style="font-size:10px;color:#999;margin-top:4px;">サービス内で表示される名前です</p>
        </div>
        <div>
          <label class="m-input-label">メールアドレス</label>
          <input class="m-input" type="email" placeholder="you@example.com">
        </div>
        <div>
          <label class="m-input-label">パスワード</label>
          <div style="position:relative;">
            <input class="m-input" type="password" placeholder="8文字以上の英数字" style="padding-right:44px;">
            <span class="material-icons-outlined" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#999;cursor:pointer;margin:0;">visibility_off</span>
          </div>
          <!-- Strength indicator -->
          <div style="display:flex;gap:4px;margin-top:6px;">
            <div style="flex:1;height:3px;border-radius:2px;background:#000;"></div>
            <div style="flex:1;height:3px;border-radius:2px;background:#000;"></div>
            <div style="flex:1;height:3px;border-radius:2px;background:#e0e0e0;"></div>
            <div style="flex:1;height:3px;border-radius:2px;background:#e0e0e0;"></div>
          </div>
          <p style="font-size:10px;color:#999;margin-top:4px;">強度: 普通</p>
        </div>
        <div>
          <label class="m-input-label">パスワード確認</label>
          <div style="position:relative;">
            <input class="m-input" type="password" placeholder="もう一度入力してください" style="padding-right:44px;">
            <span class="material-icons-outlined" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#999;cursor:pointer;margin:0;">visibility_off</span>
          </div>
        </div>
        <!-- Terms checkbox -->
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-top:4px;">
          <input type="checkbox" checked style="width:18px;height:18px;margin-top:1px;accent-color:#000;flex-shrink:0;">
          <span style="font-size:12px;color:#555;line-height:1.5;"><span style="color:#000;font-weight:500;text-decoration:underline;cursor:pointer;">利用規約</span>と<span style="color:#000;font-weight:500;text-decoration:underline;cursor:pointer;">プライバシーポリシー</span>に同意する</span>
        </label>
        <button class="m-btn m-btn-primary" style="margin-top:8px;" onclick="go('home')">アカウントを作成</button>
        <p style="text-align:center;font-size:12px;color:#999;margin-top:4px;">すでにアカウントをお持ちの方 <span style="color:#000;font-weight:600;cursor:pointer;" onclick="go('login')">ログイン</span></p>
      </div>
