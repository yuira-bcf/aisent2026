          <div style="display:flex;gap:6px;margin-top:8px;padding:0 4px;">
            <span class="m-chip" style="font-size:11px;padding:4px 10px;">
              <span class="material-icons-outlined" style="font-size:14px;margin-right:4px;">person</span>クリエーター指定
            </span>
            <span class="m-chip" style="font-size:11px;padding:4px 10px;">
              <span class="material-icons-outlined" style="font-size:14px;margin-right:4px;color:#F97316;">tune</span>詳細設定
            </span>
