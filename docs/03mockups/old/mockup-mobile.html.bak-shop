                <p style="font-size:9px;color:#999;margin-top:4px;">14:02 · v1 を生成</p>
              </div>
            </div>
            <!-- User message 2 -->
            <div style="display:flex;justify-content:flex-end;">
              <div style="max-width:78%;background:#000;color:#fff;border-radius:16px 16px 4px 16px;padding:10px 14px;">
