            <div style="display:flex;align-items:center;gap:16px;">
              <div class="donut-md" style="background:conic-gradient(#F59E0B 0% 20%,#EC4899 20% 35%,#8B5CF6 35% 50%,#3B82F6 50% 65%,#10B981 65% 80%,#F97316 80% 100%);">
