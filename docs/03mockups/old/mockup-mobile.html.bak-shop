            <div style="display:flex;gap:8px;">
              <div style="flex:1;background:#f7f7f7;border-radius:10px;padding:12px;">
                <p style="font-size:10px;font-weight:600;color:#999;margin-bottom:6px;">TOP</p>
                <p style="font-size:12px;color:#000;line-height:1.5;">レモン<br>ベルガモット</p>
              </div>
              <div style="flex:1;background:#f7f7f7;border-radius:10px;padding:12px;">
                <p style="font-size:10px;font-weight:600;color:#999;margin-bottom:6px;">MIDDLE</p>
