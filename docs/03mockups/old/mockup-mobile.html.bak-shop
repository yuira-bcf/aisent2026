          <div style="display:flex;align-items:center;gap:8px;background:#f5f5f5;border-radius:10px;padding:10px 14px;margin-bottom:16px;">
            <span class="material-icons-outlined" style="font-size:20px;color:#999;margin:0;">search</span>
            <input type="text" placeholder="お困りのことを検索..." style="flex:1;font-size:14px;border:none;background:transparent;outline:none;">
          </div>
          <!-- Quick links -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:20px;">
            <div class="m-card" style="padding:14px 8px;text-align:center;cursor:pointer;">
              <span class="material-icons-outlined" style="font-size:24px;color:#000;margin:0;">shopping_bag</span>
              <p style="font-size:11px;font-weight:500;color:#000;margin-top:6px;">注文について</p>
            </div>
            <div class="m-card" style="padding:14px 8px;text-align:center;cursor:pointer;">
              <span class="material-icons-outlined" style="font-size:24px;color:#000;margin:0;">local_shipping</span>
              <p style="font-size:11px;font-weight:500;color:#000;margin-top:6px;">配送について</p>
            </div>
            <div class="m-card" style="padding:14px 8px;text-align:center;cursor:pointer;">
              <span class="material-icons-outlined" style="font-size:24px;color:#000;margin:0;">person</span>
              <p style="font-size:11px;font-weight:500;color:#000;margin-top:6px;">アカウント</p>
            </div>
          </div>
          <!-- 注文・購入 section -->
          <p style="font-size:11px;font-weight:600;color:#999;letter-spacing:0.05em;margin-bottom:10px;">注文・購入</p>
          <div class="m-card" style="overflow:hidden;margin-bottom:16px;">
            <div style="padding:14px 16px;border-bottom:1px solid #f0f0f0;cursor:pointer;" onclick="this.querySelector('.faq-answer').style.display=this.querySelector('.faq-answer').style.display==='block'?'none':'block';this.querySelector('.faq-arrow').textContent=this.querySelector('.faq-answer').style.display==='block'?'expand_less':'expand_more'">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <p style="font-size:13px;font-weight:500;color:#000;">注文からどのくらいで届きますか？</p>
                <span class="material-icons-outlined faq-arrow" style="font-size:18px;color:#ccc;margin:0;">expand_more</span>
              </div>
              <div class="faq-answer" style="display:none;margin-top:10px;">
                <p style="font-size:12px;color:#666;line-height:1.6;">オーダーメイド製造のため、通常7〜14日でお届けします。</p>
              </div>
            </div>
            <div style="padding:14px 16px;border-bottom:1px solid #f0f0f0;cursor:pointer;" onclick="this.querySelector('.faq-answer').style.display=this.querySelector('.faq-answer').style.display==='block'?'none':'block';this.querySelector('.faq-arrow').textContent=this.querySelector('.faq-answer').style.display==='block'?'expand_less':'expand_more'">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <p style="font-size:13px;font-weight:500;color:#000;">注文のキャンセルはできますか？</p>
                <span class="material-icons-outlined faq-arrow" style="font-size:18px;color:#ccc;margin:0;">expand_more</span>
              </div>
              <div class="faq-answer" style="display:none;margin-top:10px;">
                <p style="font-size:12px;color:#666;line-height:1.6;">調香開始前であればキャンセル可能です。注文詳細ページからお手続きください。</p>
              </div>
            </div>
            <div style="padding:14px 16px;cursor:pointer;" onclick="this.querySelector('.faq-answer').style.display=this.querySelector('.faq-answer').style.display==='block'?'none':'block';this.querySelector('.faq-arrow').textContent=this.querySelector('.faq-answer').style.display==='block'?'expand_less':'expand_more'">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <p style="font-size:13px;font-weight:500;color:#000;">支払い方法は何がありますか？</p>
