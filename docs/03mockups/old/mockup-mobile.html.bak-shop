              </div>
              <div class="faq-answer" style="display:none;margin-top:10px;">
                <p style="font-size:12px;color:#666;line-height:1.6;">マイページの設定から変更可能です。</p>
              </div>
            </div>
          </div>
          <!-- Contact section -->
          <p style="font-size:11px;font-weight:600;color:#999;letter-spacing:0.05em;margin-bottom:10px;">お問い合わせ</p>
          <div class="m-card" style="padding:16px;margin-bottom:12px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <span class="material-icons-outlined" style="font-size:22px;color:#000;margin:0;">mail</span>
              <div>
                <p style="font-size:13px;font-weight:500;color:#000;">メールサポート</p>
                <p style="font-size:12px;color:#666;margin-top:2px;">support@kyarainnovate.com</p>
                <p style="font-size:11px;color:#999;margin-top:2px;">営業時間 10:00-18:00</p>
              </div>
            </div>
          </div>
          <button class="m-btn m-btn-secondary" style="font-size:13px;width:100%;">
            <span class="material-icons-outlined" style="font-size:18px;margin-right:6px;">bug_report</span>問題を報告
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== ABOUT ==================== -->
  <div id="screen-about" class="screen-wrap">
    <div class="screen-content-full" style="padding-bottom:0;">
      <div class="top-bar">
        <span class="material-icons-outlined back-btn" onclick="go('mypage')">arrow_back</span>
        <span class="top-title">アプリについて</span>
      </div>
      <div style="overflow-y:auto;height:calc(100dvh - 48px);padding-bottom:16px;">
        <!-- Hero section -->
