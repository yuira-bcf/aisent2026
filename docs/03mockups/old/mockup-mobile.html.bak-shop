        <!-- Center Content -->
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 20px;">
          <p style="font-size:22px;font-weight:700;color:#000;text-align:center;line-height:1.4;">どんな香りを<br>つくりましょう？</p>
          <p style="font-size:12px;color:#999;margin-top:6px;text-align:center;">AIが最適な調香を提案します</p>

          <!-- Suggestion Cards -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;width:100%;margin-top:24px;">
            <div class="m-card" style="padding:12px;cursor:pointer;" onclick="go('result')">
              <p style="font-size:12px;font-weight:500;color:#000;">夏のデートに<br>ぴったりの香り</p>
              <p style="font-size:10px;color:#999;margin-top:4px;">爽やか × 華やか</p>
            </div>
            <div class="m-card" style="padding:12px;cursor:pointer;" onclick="go('result')">
              <p style="font-size:12px;font-weight:500;color:#000;">落ち着いた<br>夜のリラックス</p>
              <p style="font-size:10px;color:#999;margin-top:4px;">ウッディ × ミステリアス</p>
            </div>
            <div class="m-card" style="padding:12px;cursor:pointer;" onclick="go('result')">
              <p style="font-size:12px;font-weight:500;color:#000;">オフィスでの<br>清潔感</p>
              <p style="font-size:10px;color:#999;margin-top:4px;">シトラス × クリーン</p>
            </div>
            <div class="m-card" style="padding:12px;cursor:pointer;" onclick="go('result')">
              <p style="font-size:12px;font-weight:500;color:#000;">パートナーへの<br>記念日ギフト</p>
              <p style="font-size:10px;color:#999;margin-top:4px;">情熱的 × エレガント</p>
            </div>
          </div>
        </div>

        <!-- Bottom Input -->
        <div style="padding:12px 16px 24px;background:#fff;border-top:1px solid #f0f0f0;">
          <div style="display:flex;align-items:flex-end;gap:8px;background:#f5f5f5;border-radius:20px;padding:10px 14px;">
            <textarea rows="1" placeholder="どんな香りがほしいですか？" style="flex:1;resize:none;font-size:14px;background:transparent;border:none;outline:none;color:#111;min-height:20px;max-height:80px;field-sizing:content;">夏のデートに使いたい。爽やかだけど少し甘さもある香り</textarea>
            <button style="width:32px;height:32px;border-radius:50%;background:#000;border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
